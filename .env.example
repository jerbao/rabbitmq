# ==========================================
# Local Configuration (CHANGE THIS ON EACH VM)
# ==========================================
# On VM 1 use rmq1, on VM 2 use rmq2, on VM 3 use rmq3
RABBITMQ_HOSTNAME=rmq1

# Names of the other 2 nodes (do NOT include this VM's own name).
# - On VM 1 (rmq1): rmq2, rmq3
# - On VM 2 (rmq2): rmq1, rmq3
# - On VM 3 (rmq3): rmq1, rmq2
RABBITMQ_PEER_A_NAME=rmq2
RABBITMQ_PEER_B_NAME=rmq3

# ==========================================
# Peer Node IPs (SAME ON ALL VMs)
# ==========================================
# Physical IPs of the OTHER 2 nodes (do NOT include this VM's own IP).
# RabbitMQ resolves its own hostname via the Docker bridge — adding it
# here pointing to the external IP breaks the Erlang distribution layer.
# - On VM 1 (rmq1): list IPs of rmq2 and rmq3
# - On VM 2 (rmq2): list IPs of rmq1 and rmq3
# - On VM 3 (rmq3): list IPs of rmq1 and rmq2
PEER_RMQ_A=10.0.0.12
PEER_RMQ_B=10.0.0.13

# ==========================================
# Cluster Configuration (SAME ON ALL VMs)
# ==========================================
# The cookie MUST be identical across all 3 nodes to form the cluster
RABBITMQ_ERLANG_COOKIE=place_a_random_strong_hash_here

# Default access credentials
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=yourpassword123